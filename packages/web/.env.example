# ──────────────────────────────────────────────────────────
# REQUIRED — core OTA platform
# ──────────────────────────────────────────────────────────

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/otakit?schema=public"

# API write secret for admin/CLI endpoints
SECRET_KEY="change-me"

# Public app URL for Better Auth callbacks and email links
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
BETTER_AUTH_SECRET="replace-with-a-32-char-secret"

# At least one auth provider is required
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Cloudflare R2 / S3-compatible object storage
R2_BUCKET="otakit-bundles"
R2_ACCESS_KEY="your-access-key"
R2_SECRET_KEY="your-secret-key"
R2_REGION="auto"
# Either set R2_ENDPOINT directly, or use R2_ACCOUNT_ID to derive one
R2_ENDPOINT=""
R2_ACCOUNT_ID=""

# Public URL where bundle objects and manifests are served
CDN_BASE_URL="https://cdn.example.com"

# ──────────────────────────────────────────────────────────
# OPTIONAL — hosted features (gracefully disabled if unset)
# ──────────────────────────────────────────────────────────

# Tinybird — device event analytics and dashboard counts
# Without this, dashboard analytics show empty state and billing counts return 0.
TINYBIRD_API_HOST="https://api.tinybird.co"
TINYBIRD_READ_TOKEN=""
TINYBIRD_APP_EVENTS_RECENT_PIPE="app_events_recent"
TINYBIRD_RELEASE_EVENT_COUNTS_PIPE="release_event_counts"
TINYBIRD_BUNDLE_EVENT_COUNTS_PIPE="bundle_event_counts"
TINYBIRD_ORGANIZATION_DOWNLOAD_COUNTS_PIPE="organization_download_counts"

# Resend — transactional email (OTP sign-in codes, invites, usage warnings)
# Without this, emails are logged to the server console instead of sent.
RESEND_API_KEY=""
EMAIL_FROM="OtaKit <noreply@otakit.app>"
SUPPORT_EMAIL="support@otakit.app"

# Polar — billing, plan limits, and usage enforcement
# Without this, all organizations have unlimited usage and billing UI is hidden.
POLAR_ACCESS_TOKEN=""
POLAR_WEBHOOK_SECRET=""
POLAR_SERVER="sandbox"
POLAR_PRODUCT_PRO_MONTHLY=""
POLAR_PRODUCT_SCALE_MONTHLY=""
POLAR_USAGE_EVENT_NAME="otakit.download.usage.v1"
POLAR_METER_DOWNLOADS_ID=""

# Cloudflare CDN purge — cache invalidation after release/revert
# Without this, manifests may serve stale content until CDN TTL expires.
CF_ZONE_ID=""
CF_API_TOKEN=""

# Upstash Redis — API rate limiting
# Without this, rate limiting is disabled and all requests are allowed.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Manifest signing — ES256 signature on manifest JSON
MANIFEST_SIGNING_DISABLED="false"
MANIFEST_SIGNING_KEY=""
MANIFEST_SIGNING_KID=""

# ──────────────────────────────────────────────────────────
# TUNING — optional overrides
# ──────────────────────────────────────────────────────────

ADMIN_SECRET_KEY=""
MAX_BUNDLE_SIZE="104857600"
PRESIGN_EXPIRES_SECONDS="3600"
CRON_SECRET="change-me"
BCRYPT_ROUNDS="12"
