# This file mirrors the runtime values needed by @otakit/ingest.
# Keep real secrets local only. This repo intentionally does not use .dev.vars.

# Must match your Tinybird workspace region.
TINYBIRD_API_HOST="https://api.tinybird.co"

# Raw datasource name created by the tinybird/ project.
TINYBIRD_EVENTS_DATASOURCE="device_events_raw"

# Also upload this as a Wrangler Worker secret:
# `cd packages/ingest && npx wrangler secret put TINYBIRD_EVENTS_TOKEN`
TINYBIRD_EVENTS_TOKEN=""
